{
    "data_path": "risk_assessment/data/csvfile/calories_dataset.csv",
    "model_name": "calories",
    "model_name_en": "Calories",
    "model_type": "regression",
    "model_path": "risk_assessment/models/calories",
    "result_path": "risk_assessment/results/calories",
    "target_column": "Calories",
    "feature_columns": {
        "Calories": {
            "description": "本次运动消耗的卡路里（单位：千卡，回归目标）",
            "description_en": "Calories burned in this exercise (unit: kcal, regression target)",
            "type": "numerical",
            "values": ["千卡"]
        },
        "Gender": {
            "description": "性别（女/男）",
            "description_en": "Gender (Female/Male)",
            "type": "categorical",
            "values": ["女", "男"],
            "values_en": ["Female", "Male"],
            "mapping": {"女": 0, "男": 1}
        },
        "Age": {
            "description": "年龄（单位：岁）",
            "description_en": "Age (unit: years)",
            "type": "numerical",
            "values": ["岁"]
        },
        "Height": {
            "description": "身高（单位：厘米）",
            "description_en": "Height (unit: cm)",
            "type": "numerical",
            "values": ["厘米"]
        },
        "Weight": {
            "description": "体重（单位：千克）",
            "description_en": "Weight (unit: kg)",
            "type": "numerical",
            "values": ["千克"]
        },
        "Duration": {
            "description": "运动时长（单位：分钟）",
            "description_en": "Exercise duration (unit: minutes)",
            "type": "numerical",
            "values": ["分钟"]
        },
        "Heart_Rate": {
            "description": "运动过程中的心率（单位：次/分钟）",
            "description_en": "Heart rate during exercise (unit: beats/minute)",
            "type": "numerical",
            "values": ["次/分钟"]
        },
        "Body_Temp": {
            "description": "运动时体温（单位：摄氏度）",
            "description_en": "Body temperature during exercise (unit: Celsius)",
            "type": "numerical",
            "values": ["摄氏度"]
        }
    }
}
