{
    "data_path": "risk_assessment/data/csvfile/heart_failure_clinical_records_dataset.csv",
    "model_name": "heart_failure_clinical_records",
    "model_name_en": "Heart Failure",
    "model_type": "binary",
    "model_path": "risk_assessment/models/heart_failure_clinical_records",
    "result_path": "risk_assessment/results/heart_failure_clinical_records",
    "target_column": "DEATH_EVENT",
    "target_mapping_draw": {
        "0": "存活",
        "1": "死亡"
    },
    "target_mapping_draw_en": {
        "0": "Alive",
        "1": "Dead"
    },
    "feature_columns": {
        "DEATH_EVENT": {
            "description": "是否在随访期间死亡（1=死亡，0=存活）",
            "description_en": "Did death occur during follow-up period? (1=Dead, 0=Alive)",
            "type": "categorical",
            "values": ["存活", "死亡"],
            "values_en": ["Alive", "Dead"],
            "mapping": {"存活": 0, "死亡": 1}
        },
        "age": {
            "description": "年龄（单位：岁）",
            "description_en": "Age (unit: years)",
            "type": "numerical",
            "values": ["岁"]
        },
        "anaemia": {
            "description": "是否患有贫血（1=是，0=否）",
            "description_en": "Do you have anaemia? (1=Yes, 0=No)",
            "type": "categorical",
            "values": ["否", "是"],
            "values_en": ["No", "Yes"],
            "mapping": {"否": 0, "是": 1}
        },
        "creatinine_phosphokinase": {
            "description": "肌酸激酶水平（U/L，反映肌肉损伤）",
            "description_en": "Creatinine phosphokinase level (U/L, reflects muscle damage)",
            "type": "numerical",
            "values": ["U/L"]
        },
        "diabetes": {
            "description": "是否患有糖尿病（1=是，0=否）",
            "description_en": "Do you have diabetes? (1=Yes, 0=No)",
            "type": "categorical",
            "values": ["否", "是"],
            "values_en": ["No", "Yes"],
            "mapping": {"否": 0, "是": 1}
        },
        "ejection_fraction": {
            "description": "射血分数（%）越低表示心功能越差",
            "description_en": "Ejection fraction (%) - lower values indicate worse heart function",
            "type": "numerical",
            "values": ["%"]
        },
        "high_blood_pressure": {
            "description": "是否患有高血压（1=是，0=否）",
            "description_en": "Do you have high blood pressure? (1=Yes, 0=No)",
            "type": "categorical",
            "values": ["否", "是"],
            "values_en": ["No", "Yes"],
            "mapping": {"否": 0, "是": 1}
        },
        "platelets": {
            "description": "血小板数量（单位：k/μL）",
            "description_en": "Platelet count (unit: k/μL)",
            "type": "numerical",
            "values": ["k/μL"]
        },
        "serum_creatinine": {
            "description": "血清肌酐（mg/dL，反映肾功能）",
            "description_en": "Serum creatinine (mg/dL, reflects kidney function)",
            "type": "numerical",
            "values": ["mg/dL"]
        },
        "serum_sodium": {
            "description": "血清钠（mEq/L）",
            "description_en": "Serum sodium (mEq/L)",
            "type": "numerical",
            "values": ["mEq/L"]
        },
        "sex": {
            "description": "性别（1=男，0=女）",
            "description_en": "Gender (1=Male, 0=Female)",
            "type": "categorical",
            "values": ["女", "男"],
            "values_en": ["Female", "Male"],
            "mapping": {"女": 0, "男": 1}
        },
        "smoking": {
            "description": "是否吸烟（1=是，0=否）",
            "description_en": "Do you smoke? (1=Yes, 0=No)",
            "type": "categorical",
            "values": ["否", "是"],
            "values_en": ["No", "Yes"],
            "mapping": {"否": 0, "是": 1}
        },
        "time": {
            "description": "随访时间（单位：天）",
            "description_en": "Follow-up time (unit: days)",
            "type": "numerical",
            "values": ["天"]
        }
    }
}
